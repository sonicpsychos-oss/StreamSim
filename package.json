{
  "name": "streamsim",
  "version": "0.9.7",
  "description": "StreamSim MVP control center + overlay simulation engine",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "ci:slo": "tsx scripts/check-slo.ts",
    "ci:trace-gate": "tsx scripts/check-slo.ts --trace=data/traces/realistic-latency-trace.json",
    "ci:release-checklist": "tsx scripts/check-release-checklist.ts",
    "ci:capture-traces": "tsx scripts/capture-nfr-traces.ts"
  },
  "dependencies": {
    "@deepgram/sdk": "^5.0.0",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.8.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
